---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <a class="brand footer-brand" href={base}>
        <img class="brand-logo" src={`${base}images/logo.jpeg`} alt="" width="44" height="44" />
        <span>GenZ Africa</span>
      </a>
      <p>
        Une communauté d'entraide pour apprendre, partager les opportunités et construire un réseau utile.
      </p>
    </div>
    <div>
      <h2>Navigation</h2>
      <a href={`${base}ressources/`}>Ressources</a>
      <a href={`${base}a-propos/`}>À propos</a>
      <a href={`${base}contact/`}>Contact</a>
    </div>
    <div>
      <h2>Réseaux</h2>
      <a href="https://x.com/genZ_Africa226" target="_blank" rel="noreferrer">X / Twitter</a>
      <a href="https://wa.me/22676956827" target="_blank" rel="noreferrer">WhatsApp</a>
      <a href="https://www.linkedin.com/company/genz-africa/" target="_blank" rel="noreferrer">LinkedIn</a>
    </div>
  </div>
  <p class="copyright">© {year} GenZ Africa. Tous droits réservés.</p>
</footer>
