---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout
  title="Contact | GenZ Africa"
  description="Contactez GenZ Africa, suivez la communauté ou rejoignez le réseau d'entraide des étudiants et jeunes professionnels burkinabè."
>
  <section class="page-hero compact-hero">
    <div class="section-inner">
      <span class="eyebrow">Contact</span>
      <h1>Une ressource, une opportunité ou une idée à partager ?</h1>
      <p>
        GenZ Africa reste volontairement simple: des liens directs pour suivre la communauté, échanger et rejoindre le réseau.
      </p>
    </div>
  </section>

  <section class="section contact-grid" aria-label="Moyens de contact">
    <a class="contact-card" href="https://x.com/genZ_Africa226" target="_blank" rel="noreferrer">
      <span>X / Twitter</span>
      <strong>Suivre les annonces</strong>
      <p>@genZ_Africa226</p>
    </a>
    <a class="contact-card" href="https://wa.me/22676956827" target="_blank" rel="noreferrer">
      <span>WhatsApp</span>
      <strong>Écrire sur WhatsApp</strong>
      <p>+226 76 95 68 27</p>
    </a>
    <a class="contact-card" href="https://www.linkedin.com/company/genz-africa/" target="_blank" rel="noreferrer">
      <span>LinkedIn</span>
      <strong>Suivre la page</strong>
      <p>GenZ Africa</p>
    </a>
    <a class="contact-card featured" href="mailto:bousairou@gmail.com?subject=Rejoindre%20GenZ%20Africa&body=Bonjour%2C%0A%0AJe%20souhaite%20rejoindre%20GenZ%20Africa.%0A%0ANom%20%3A%20%0APr%C3%A9nom%20%3A%20%0AFili%C3%A8re%20d%27%C3%A9tude%20ou%20fonction%20%3A%20%0ANum%C3%A9ro%20WhatsApp%20%3A%20%0A%0AMerci.">
      <span>Communauté</span>
      <strong>Rejoindre GenZ Africa</strong>
      <p>Envoyer nom, prénom, filière ou fonction et numéro WhatsApp.</p>
    </a>
  </section>
</BaseLayout>
